{
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost;Database=DailyRentalHomes;Trusted_Connection=True;TrustServerCertificate=True"
  },
  "Token": {
    "Issuer": "DailyRentalHomes",
    "Audience": "DailyRentalHomesClients",
    "Key": "",
    "Minutes": 1440
  },
  "Notifications": {
    "WorkerEnabled": false,
    "PollSeconds": 30,
    "BatchSize": 20
  },
  "NotificationDelivery": {
    "Provider": "Fake",
    "MetaWhatsApp": {
      "PhoneNumberId": "",
      "AccessToken": "",
      "ApiVersion": "",
      "WebhookVerifyToken": "",
      "AppSecret": "",
      "DefaultLanguageCode": "az",
      "Templates": {
        "deposit_deadline_reminder": "deposit_deadline_reminder",
        "deposit_deadline_extended": "deposit_deadline_extended"
      }
    },
    "Retry": {
      "MaxAttempts": 5,
      "InitialDelayMinutes": 2,
      "MaxDelayMinutes": 60
    }
  },
  "DepositReminderOptions": {
    "ReminderBeforeHours": 24,
    "ProcessingIntervalMinutes": 15
  },
  "FileStorage": {
    "Provider": "Local",
    "Local": {
      "RootPath": "uploads",
      "PublicBasePath": "/uploads"
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
